          <body name="link3" pos="0.28358 0.028726 0" quat="0.998726 0 0 0.0504536" gravcomp="1">
            <inertial pos="-0.0996835 0.0349477 0.000508026"
                      quat="0.0777021 0.702287 -0.0990541 0.700674" mass="0.290848"
