                <geom mesh="link5_8" material="gray_mat" class="piper_visual"/>
                <geom mesh="link5" class="piper_collision"/>

                <body name="link6" pos="0 0.091 0.0014165" quat="0 0 -0.707105 -0.707108" gravcomp="1">
                  <inertial pos="0.0010312 0.0121761 0.0315481"
                            quat="0.0230402 0.707091 0.0373344 0.70576" mass="1.2"
                            diaginertia="0.001 0.001 0.001"/>
                  <joint name="joint6" axis="0 0 1" range="-3.14 3.14"/>
                  <geom quat="0.707105 0 0 0.707108" mesh="link6" material="gray_mat" class="piper_visual"/>
                  <geom quat="0.707105 0 0 0.707108" mesh="link6" class="piper_collision"/>

                  <!-- ==========================================================
                       SITE: tool point at the flange face
                       Useful as an IK target reference and for visualization.
                       Marks the "flange origin" — RUKA's mount sits 10cm forward (+Z) of here.
                       ========================================================== -->
                  <site name="flange" pos="0 0 0" size="0.005" rgba="0 1 0 1"/>

                  <!-- ==========================================================
                       SITE: grasp reference point for IK targeting
                       Position: 18cm along link6 +Z = at the knuckle line
                                 (middle/ring finger MCP joints). This is
                                 where contact happens during a grasp —
                                 a more accurate IK target than the palm
                                 center (which was at z=0.15).
                       Frame:    inherits link6's frame (no rotation specified).
                       Visual:   small magenta sphere for visual debugging.
                       ========================================================== -->
                  <site name="palm" pos="0 0 0.18" size="0.008" rgba="1 0 1 1"/>

                  <!-- ==========================================================
                       MOUNT: RUKA palm attaches as child of link6
                       pos="0 0 0.10"            →  10cm along link6 +Z
                                                    Empirically tuned: smaller values
                                                    (0.05–0.06) caused the back-flange
                                                    of the RUKA palm STL to penetrate
                                                    link6's wrist housing. 0.10 leaves
                                                    a small visible gap representing
                                                    a notional wrist adapter plate.
                       quat="0 0.707 0.707 0"    →  180° around (1,1,0)/√2 in link6 frame
                       After rotation:
                         - RUKA's −Z (fingers extend) → link6 +Z (approach axis) ✅
                         - RUKA's +Y (palm-out)        → link6 +X
                         - RUKA's +X (thumb side)      → link6 +Y
                       Effect at home pose: palm-out faces world +X (workspace ahead),
                       thumb points up (world +Z), fingers extend forward.
                       ========================================================== -->
                  <body name="ruka_palm" pos="0 0 0.10" quat="0 0.707 0.707 0" childclass="ruka" gravcomp="1">
                    <!-- Inertial: synthesize a reasonable lumped palm inertia
                         (RUKA's source uses settotalmass="1" which we are NOT carrying over;
                         we want explicit physical units in our combined model.) -->
                    <inertial pos="0 0 -0.04" mass="0.15" diaginertia="0.0002 0.0002 0.0001"/>

                    <geom type="mesh" mesh="ruka_Palm" material="ruka_mat" class="ruka_visual"
                          name="ruka_palm_visual"/>
                    <geom type="box" size="0.042 0.0105 0.058" pos="0.004 0.009 -0.02"
                          class="ruka_collision" name="ruka_palm_collision"/>

                    <!-- (Note: the IK-target site for grasp execution is "palm",
                         defined inside link6 above — not here. We need its frame
                         to match link6's frame, but ruka_palm is rotated 180°
                         from link6 by the mount transform.) -->

                    <!-- ==========================================================
                         WRIST-MOUNTED CAMERA (eye-in-hand, fixed orientation)
                         RealSense-D435-like: 640x480, fovy=58°, depth 0.2-2m.

                         Mounted on the back of the palm, looking in the
                         finger-extension direction (palm -Z). At the home
                         pose this points roughly forward+slightly-down at
                         the workspace.

                         The xyaxes encode camera +X (image right) and +Y
                         (image up) in palm-local coordinates:
                           +X = (-1, 0, 0)  → image right is palm -X
                           +Y = (0, -1, 0)  → image up    is palm -Y
                           camera +Z = X × Y = (0, 0, 1) = palm +Z
                           camera looks along -Z = palm -Z = finger direction ✓

                         The negative signs (vs the natural (1,0,0)/(0,1,0))
                         rotate the image 180° around the look axis — without
                         this rotation the captured image was upside-down. -->
                    <camera name="wrist_cam"
                            pos="0 -0.04 0.02"
                            xyaxes="-1 0 0  0 -1 0"
                            fovy="58"/>

                    <!-- ===== Index finger ===== -->
                    <body name="ruka_index_mcp" pos="0.0322 0.0146007 -0.08022"
                          quat="-0.410779 0.525515 0.556422 0.495469" gravcomp="1">
                      <inertial pos="0.0288724 -1.28993e-08 0.00378475"
