<mujoco model="piper_ruka">
  <!-- ============================================================================
       PIPER ARM + RUKA HAND — UNIFIED MJCF
       ============================================================================
       Convention: Z-up (MuJoCo default). Gravity NOT overridden (default 0 0 -9.81).
       
       Mount transform (link6 → ruka_palm):
         pos  = "0 0 0.10"          →  10 cm forward of link6 origin along link6 +Z
                                       Empirically tuned: smaller values (0.05–0.06)
                                       caused the back-flange of the RUKA palm STL to
                                       penetrate link6's wrist housing. 0.10 leaves a
                                       small visible gap representing a notional wrist
                                       adapter plate.
         quat = "0 0.707 0.707 0"   →  180° rotation around the diagonal axis (1,1,0)/√2
                                       expressed in link6's frame.
                                       Effect on RUKA's frame:
                                         RUKA +X (thumb side) → link6 +Y
                                         RUKA +Y (palm-out)   → link6 +X
                                         RUKA −Z (fingers)    → link6 +Z   ← tool axis

                                       The (1,1,0) rotation simultaneously aligns the
                                       finger axis with the tool axis AND places the thumb
                                       in link6 +Y. The 4-finger fan ends up in the +X/+Z
                                       plane of link6. Result: at the Piper home pose
                                       (joint2=1.57, joint3=-1.3485) the hand presents the
                                       palm "out" toward the workspace and the thumb "up"
                                       in world coordinates — natural for visualisation
                                       and reachable across the full grasp space via
                                       joint5/joint6 wrist articulation.

         An equivalent simpler quat would be "0 1 0 0" (180° around X), which also aligns
         fingers with the tool axis but rotates the palm 90° around that axis vs. the
         current choice. Both are kinematically valid; we picked (1,1,0) for the
         human-intuitive home pose where the palm naturally faces the workspace
         (toward the floor / table) at Piper's default joint angles.

       What was deleted from the original Piper MJCF:
         - <body name="link7"> ... gripper finger 1
         - <body name="link8"> ... gripper finger 2
         - <equality> ... </equality> (coupled the two gripper fingers)
         - <position name="gripper" .../> actuator
         - <light spotlight target="link8" .../> (retargeted in scene file)

       What was deleted from the original RUKA MJCF:
         - <option gravity="0 -9.81 0"/> (Y-up — would break Piper)
         - <body name="world_frame"> wrapper (we re-parent to link6)
         - <joint name="Palm_Joint" type="slide" .../> (degenerate, unused)

       Renaming policy: all RUKA bodies / joints / geoms / actuators are prefixed
       with "ruka_" to avoid name collision with Piper and to make ownership obvious.
       ============================================================================ -->

  <compiler angle="radian" autolimits="true"/>
  <option integrator="implicitfast" cone="elliptic" impratio="10"/>

  <default>
    <!-- ============== Piper class (unchanged from Menagerie) ============== -->
    <default class="piper">
      <joint frictionloss="0.3" armature="0.005"/>
      <position inheritrange="1" forcerange="-100 100"/>
      <default class="piper_visual">
        <geom group="2" type="mesh" contype="0" conaffinity="0" density="0"/>
      </default>
      <default class="piper_collision">
        <geom group="3" type="capsule"/>
      </default>
    </default>

    <!-- ============== RUKA class (renamed to avoid collisions) ============== -->
    <default class="ruka">
      <default class="ruka_visual">
        <geom friction="1 0.005 0.001" conaffinity="0" contype="0" condim="3" group="2"/>
      </default>
      <default class="ruka_joint">
        <joint damping="0.05" armature="0.001" frictionloss="0.01"/>
      </default>
      <default class="ruka_collision">
        <geom group="3" friction="1.5 0.01 0.001" conaffinity="2" contype="2"
              condim="3" rgba="0 0.5 0.5 0.3" density="0" margin="0.001"/>
      </default>
    </default>
  </default>

  <asset>
