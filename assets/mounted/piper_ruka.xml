  <worldbody>
    <!-- ============================================================================
         PIPER ARM CHAIN: base_link → link1 → link2 → link3 → link4 → link5 → link6
         (Verbatim from Menagerie except link7/link8 are dropped at the end of link6.)
         ============================================================================ -->
    <body name="base_link" pos="0 0 0.70" childclass="piper" gravcomp="1">
      <inertial pos="-0.00979275 1.82906e-06 0.04101"
                quat="0.692988 -0.137524 -0.137826 0.69416" mass="0.162549"
