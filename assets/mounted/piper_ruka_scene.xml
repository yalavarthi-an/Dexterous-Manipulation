<mujoco model="piper_ruka_scene">
  <!-- Minimal scene for sanity-testing the mounted Piper+RUKA.
       Loads the robot, adds a floor, lights, and a visualization camera.
       Real tabletop + YCB scene comes in Task 2. -->

  <include file="piper_ruka.xml"/>

  <statistic center="0.3 0 0.3" extent="0.8" meansize="0.05"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2"/>
    <global azimuth="120" elevation="-20"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light name="top" pos="0 0 1.5" dir="0 0 -1" diffuse="0.7 0.7 0.7"/>
    <light name="side" pos="1 1 1" dir="-1 -1 -1" diffuse="0.4 0.4 0.4"/>
    <geom name="floor" type="plane" size="2 2 0.05" material="groundplane"/>
  </worldbody>
</mujoco>
